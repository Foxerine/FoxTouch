<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Network -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Overlay (floating bubble) -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />

    <!-- Voice input -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Notifications (required on API 33+ for foreground service notifications) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Required for VoiceInteractionService (digital assistant) -->
    <uses-permission android:name="android.permission.BIND_VOICE_INTERACTION" />

    <!-- Keep screen on while agent works -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PROJECTION" />

    <!--
        Package visibility: Android 11+ restricts getInstalledApplications().
        Declaring the MAIN/LAUNCHER intent query makes all launchable apps
        visible to ListAppsTool, LaunchAppTool, and DeviceContext.
    -->
    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".FoxTouchApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.FoxTouch"
        tools:targetApi="35">

        <!-- Required for specialUse foreground service type on Android 14+ (API 34) -->
        <property
            android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
            android:value="Agent tool approval notifications while working in background" />

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.FoxTouch"
            android:windowSoftInputMode="adjustResize">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.ASSIST" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </activity>

        <!-- Transparent Activity for clipboard reading (gains focus, reads, finishes) -->
        <activity
            android:name=".accessibility.ClipboardReaderActivity"
            android:theme="@style/Theme.FoxTouch.Transparent"
            android:taskAffinity=""
            android:excludeFromRecents="true"
            android:noHistory="true"
            android:exported="false" />

        <!-- FoxTouch IME: invisible keyboard for programmatic text input + clipboard access -->
        <service
            android:name=".ime.FoxTouchIME"
            android:label="FoxTouch Input"
            android:permission="android.permission.BIND_INPUT_METHOD"
            android:exported="true">
            <intent-filter>
                <action android:name="android.view.InputMethod" />
            </intent-filter>
            <meta-data
                android:name="android.view.im"
                android:resource="@xml/ime_method" />
        </service>

        <!-- Floating Bubble Service -->
        <service
            android:name=".ui.overlay.FloatingBubbleService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Agent Foreground Service: keeps process alive while agent works in background -->
        <service
            android:name=".agent.AgentForegroundService"
            android:exported="false"
            android:foregroundServiceType="specialUse" />

        <!-- Screen Capture Service: holds MediaProjection for enhanced screenshot mode -->
        <service
            android:name=".accessibility.ScreenCaptureService"
            android:exported="false"
            android:foregroundServiceType="mediaProjection" />

        <!-- Accessibility Service -->
        <service
            android:name=".accessibility.FoxTouchA11yService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/accessibility_service_config" />
        </service>

        <!-- Voice Interaction Service (Digital Assistant) -->
        <service
            android:name=".assistant.FoxTouchVoiceInteractionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION">
            <meta-data
                android:name="android.voice_interaction"
                android:resource="@xml/voice_interaction_service" />
            <intent-filter>
                <action android:name="android.service.voice.VoiceInteractionService" />
            </intent-filter>
        </service>

        <service
            android:name=".assistant.FoxTouchSessionService"
            android:exported="true"
            android:permission="android.permission.BIND_VOICE_INTERACTION" />

    </application>

</manifest>

<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!--
        Allow cleartext HTTP for user-configured local API endpoints
        (e.g. http://192.168.x.x proxies, local LLM servers).
        HTTPS certificate validation is still enforced for secure connections.
    -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
